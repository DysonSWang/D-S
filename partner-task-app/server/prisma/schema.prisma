// Partner Task App - Prisma Schema (SQLite compatible)
// 伙伴任务打卡系统 - 数据库模型

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

// ==================== 用户系统 ====================

/// 用户表
model User {
  id              Int      @id @default(autoincrement())
  username        String   @unique
  passwordHash    String
  role            String   @default("GROWER") // ADMIN/GUIDE/GROWER
  nickname        String?
  avatarUrl       String?
  email           String?  @unique
  phone           String?
  timezone        String   @default("Asia/Shanghai")
  status          Int      @default(1) // 0 禁用 1 正常
  safetyWordYellow String?
  safetyWordRed   String?
  ageVerified     Boolean  @default(false)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  // 关系
  guideRelationships   Relationship[] @relation("GuideRelationships")
  growerRelationships  Relationship[] @relation("GrowerRelationships")
  taskGuide            Task[]         @relation("TaskGuide")
  taskGrower           Task[]         @relation("TaskGrower")
  rewards              Reward?
  cottage              Cottage?
  decorations          UserDecoration[]
  achievements         UserAchievement[]
  notifications        Notification[]
  messageSender        Message[]      @relation("MessageSender")
  messageReceiver      Message[]      @relation("MessageReceiver")

  @@index([username])
  @@index([email])
  @@index([role])
}

// ==================== 关系系统 ====================

/// 伙伴关系表
model Relationship {
  id                  Int      @id @default(autoincrement())
  guideId             Int
  guide               User     @relation("GuideRelationships", fields: [guideId], references: [id])
  growerId            Int
  grower              User     @relation("GrowerRelationships", fields: [growerId], references: [id])
  mode                String   @default("PARTNER") // PARTNER/GUIDE_GROWER
  status              String   @default("PENDING") // PENDING/ACTIVE/DISSOLVING/DISSOLVED
  startDate           DateTime?
  endDate             DateTime?
  agreementContent    String?
  guideSign           String?
  growerSign          String?
  coolingOffDeadline  DateTime?
  createdAt           DateTime @default(now())
  updatedAt          DateTime @updatedAt

  // 关系中的任务
  tasks               Task[]

  @@unique([guideId, growerId])
  @@index([guideId])
  @@index([growerId])
  @@index([status])
}

// ==================== 任务系统 ====================

/// 任务表
model Task {
  id              Int      @id @default(autoincrement())
  relationshipId  Int
  relationship    Relationship @relation(fields: [relationshipId], references: [id])
  guideId         Int
  guide           User     @relation("TaskGuide", fields: [guideId], references: [id])
  growerId        Int
  grower          User     @relation("TaskGrower", fields: [growerId], references: [id])
  templateId      Int?
  type            String?
  name            String
  description     String?
  difficulty      Int      @default(1) // 1-5
  status          String   @default("PENDING") // PENDING/IN_PROGRESS/PENDING_REVIEW/COMPLETED/FAILED/ARCHIVED
  proofType       String   @default("TEXT") // TEXT/IMAGE/VIDEO/NONE
  proofContent    String?
  rewardConfig    String?  // JSON
  suggestionConfig String?
  deadline        DateTime?
  startedAt       DateTime?
  completedAt     DateTime?
  auditedAt       DateTime?
  auditedBy       Int?
  auditComment    String?
  repeatType      String   @default("NONE") // NONE/DAILY/WEEKLY/MONTHLY/CUSTOM
  repeatConfig    String?  // JSON
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([guideId])
  @@index([growerId])
  @@index([status])
  @@index([relationshipId])
}

// ==================== 任务模板 ====================

/// 任务模板表
model TaskTemplate {
  id          Int      @id @default(autoincrement())
  creatorId   Int
  name        String
  description String?
  difficulty  Int      @default(1)
  category    String?
  tags        String?  // JSON array
  isPublic    Boolean  @default(false)
  usageCount  Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([creatorId])
  @@index([isPublic])
  @@index([category])
}

// ==================== 奖励系统 ====================

/// 奖励资产表
model Reward {
  id        Int      @id @default(autoincrement())
  growerId  Int      @unique
  grower    User     @relation(fields: [growerId], references: [id])
  bones     Int      @default(0)
  fish      Int      @default(0)
  gems      Int      @default(0)
  hearts    Int      @default(0)
  stars     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // 奖励流水
  transactions RewardTransaction[]
}

/// 奖励流水表
model RewardTransaction {
  id        Int      @id @default(autoincrement())
  rewardId  Int
  reward    Reward   @relation(fields: [rewardId], references: [id])
  type      String   // EARN/SPEND/GIFT/REVOKE
  amount    Int
  balance   Int      // 交易后余额
  reason    String?
  taskId    Int?
  createdAt DateTime @default(now())

  @@index([rewardId])
  @@index([type])
}

// ==================== 装饰系统 ====================

/// 装饰物品表
model Decoration {
  id          Int      @id @default(autoincrement())
  name        String
  category    String   @default("FURNITURE") // HOUSE/FURNITURE/WALL/PLANT/EFFECT/PET
  rarity      Int      @default(1) // 1 普通/2 稀有/3 史诗/4 传说
  priceType   String   @default("BONES") // BONES/FISH/GEMS
  price       Int
  warmthBonus Int      @default(0)
  imageUrl    String?
  description String?
  isAvailable Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // 用户拥有的装饰
  userDecorations UserDecoration[]

  @@index([category])
}

/// 用户装饰物品表
model UserDecoration {
  id           Int      @id @default(autoincrement())
  userId       Int
  user         User     @relation(fields: [userId], references: [id])
  decorationId Int
  decoration   Decoration @relation(fields: [decorationId], references: [id])
  quantity     Int      @default(1)
  isEquipped   Boolean  @default(false)
  position     String?  // JSON {x, y, rotation}
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@unique([userId, decorationId])
  @@index([userId])
}

// ==================== 小屋系统 ====================

/// 小屋表
model Cottage {
  id            Int      @id @default(autoincrement())
  growerId      Int      @unique
  grower        User     @relation(fields: [growerId], references: [id])
  level         Int      @default(1)
  experience    Int      @default(0)
  warmth        Int      @default(0)
  theme         String?
  backgroundUrl String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([growerId])
}

// ==================== 成就系统 ====================

/// 成就表
model Achievement {
  id          Int      @id @default(autoincrement())
  name        String
  description String
  iconUrl     String?
  category    String?
  condition   String   // JSON 条件
  points      Int      @default(0)
  createdAt   DateTime @default(now())

  userAchievements UserAchievement[]

  @@index([category])
}

/// 用户成就表
model UserAchievement {
  id             Int      @id @default(autoincrement())
  userId         Int
  user           User     @relation(fields: [userId], references: [id])
  achievementId  Int
  achievement    Achievement @relation(fields: [achievementId], references: [id])
  unlockedAt     DateTime @default(now())
  progress       Int      @default(0)
  isClaimed      Boolean  @default(false)

  @@unique([userId, achievementId])
  @@index([userId])
}

// ==================== 消息系统 ====================

/// 通知表
model Notification {
  id        Int      @id @default(autoincrement())
  userId    Int
  user      User     @relation(fields: [userId], references: [id])
  type      String   @default("SYSTEM") // SYSTEM/TASK/RELATIONSHIP/REWARD/ACHIEVEMENT
  title     String
  content   String?
  isRead    Boolean  @default(false)
  link      String?
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([isRead])
}

/// 私信表
model Message {
  id         Int      @id @default(autoincrement())
  senderId   Int
  sender     User     @relation("MessageSender", fields: [senderId], references: [id])
  receiverId Int
  receiver   User     @relation("MessageReceiver", fields: [receiverId], references: [id])
  content    String
  isRead     Boolean  @default(false)
  createdAt  DateTime @default(now())

  @@index([senderId])
  @@index([receiverId])
  @@index([createdAt])
}

// ==================== 系统配置 ====================

/// 系统配置表
model SystemConfig {
  id        Int      @id @default(autoincrement())
  key       String   @unique
  value     String
  type      String   @default("string")
  updatedAt DateTime @updatedAt

  @@index([key])
}

/// 敏感词表
model SensitiveWord {
  id        Int      @id @default(autoincrement())
  word      String   @unique
  category  String
  level     Int      @default(1) // 1 警告 2 屏蔽 3 封禁
  createdAt DateTime @default(now())

  @@index([category])
}
